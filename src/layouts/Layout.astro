---
import '../styles/global.css';
import { ui, type Language } from '../i18n/ui';

const {
    title,
    description,
    lang = 'es',
    currentPath = '/',
    ogType = 'website'
} = Astro.props;

const currentLang = lang as Language;
const t = ui[currentLang];

const pageTitle = title ?? t.siteName;
const pageDescription = description ?? t.footerText;

const siteUrl = 'https://economiadetras.com';
const canonicalUrl = `${siteUrl}${currentPath}`;

const paths = {
    es: {
        home: '/es/',
        articles: '/es/articles/',
        about: '/es/about/',
        contact: '/es/contact/',
        privacy: '/es/privacy/'
    },
    en: {
        home: '/en/',
        articles: '/en/articles/',
        about: '/en/about/',
        contact: '/en/contact/',
        privacy: '/en/privacy/'
    },
    it: {
        home: '/it/',
        articles: '/it/articles/',
        about: '/it/about/',
        contact: '/it/contact/',
        privacy: '/it/privacy/'
    }
};

const p = paths[currentLang];

const getLocalizedPath = (targetLang: Language) => {
    return currentPath.replace(/^\/(es|en|it)/, `/${targetLang}`);
};

const hreflangUrls = {
    es: `${siteUrl}${getLocalizedPath('es')}`,
    en: `${siteUrl}${getLocalizedPath('en')}`,
    it: `${siteUrl}${getLocalizedPath('it')}`,
};
---

<!DOCTYPE html>
<html lang={currentLang}>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription}>
    <link rel="canonical" href={canonicalUrl}>
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/images/apple-touch-icon.png">

    <!-- hreflang: indica a Google las versiones por idioma -->
    <link rel="alternate" hreflang="es" href={hreflangUrls.es}>
    <link rel="alternate" hreflang="en" href={hreflangUrls.en}>
    <link rel="alternate" hreflang="it" href={hreflangUrls.it}>
    <link rel="alternate" hreflang="x-default" href={hreflangUrls.es}>

    <!-- Open Graph -->
    <meta property="og:type" content={ogType}>
    <meta property="og:title" content={pageTitle}>
    <meta property="og:description" content={pageDescription}>
    <meta property="og:url" content={canonicalUrl}>
    <meta property="og:locale" content={currentLang === 'es' ? 'es_ES' : currentLang === 'en' ? 'en_GB' : 'it_IT'}>
    <meta property="og:site_name" content="Economía Detrás del Titular">
    <meta property="og:image" content={`${siteUrl}/images/dt-logo.png`}>
    <meta property="og:image:alt" content={pageTitle}>
</head>

<body>
    <header>
        <div class="container wide header-inner">
            <a class="logo" href={p.home}>
                <img src="/images/dt-logo.png" alt="DT" class="logo-icon" />
                <span>{t.siteName}</span>
            </a>
            <nav>
                <a href={p.home}>{t.home}</a>
                <a href={p.articles}>{t.articles}</a>
                <a href={p.about}>{t.about}</a>
                <a href={p.contact}>{t.contact}</a>
            </nav>

            <div class="language-switcher">
                <a href={getLocalizedPath('es')}>ES</a>
                <a href={getLocalizedPath('en')}>EN</a>
                <a href={getLocalizedPath('it')}>IT</a>
            </div>
        </div>
    </header>

    <main>
        <slot />
    </main>

    <footer>
        <div class="container wide footer-inner">
            <p>© 2026 {t.siteName}</p>
            <a href={p.privacy}>{t.privacy}</a>
        </div>
    </footer>
</body>
</html>